        {
            "parameters": {
                "mode": "runOnceForEachItem",
                "jsCode": "const body = $input.item.json.body || {};\nif (!body.messages || body.messages.length === 0) {\n  throw new Error(\"Faltan mensajes en la transcripción\");\n}\nif (!body.survey_id) {\n  throw new Error(\"Falta survey_id\");\n}\nlet transcript = \"\";\nfor (const msg of body.messages) {\n  const role = msg.role === 'user' ? 'Cliente' : 'Agente';\n  transcript += `${role}: ${msg.content}\\n`;\n}\nreturn [{\n  id: body.survey_id,\n  transcription: transcript.trim()\n}];"
            },
