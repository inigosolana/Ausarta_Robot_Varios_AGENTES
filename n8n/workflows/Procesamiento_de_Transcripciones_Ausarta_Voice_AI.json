        {
            "parameters": {
                "mode": "runOnceForEachItem",
                "jsCode": "const agent = $input.item.json;\nconst transcriptNode = $('FormatTranscription').first().json;\nconst isNumeric = agent.name && agent.name.toLowerCase().includes('dakota');\nlet prompt = `Eres un asistente supervisor que audita y extrae información de transcripciones de llamadas comerciales.\\nDebes devolver OBLIGATORIAMENTE un objeto JSON estructurado:\\n\\nSi la encuesta es de TIPO NUMÉRICO (evaluaciones de 1 a 10):\\n{\\n  \"nota_comercial\": (número del 1 al 10 o null),\\n  \"nota_instalador\": (número del 1 al 10 o null),\\n  \"nota_rapidez\": (número del 1 al 10 o null),\\n  \"comentarios\": \"Breve resumen.\"\\n}\\n\\nSi la encuesta es de TIPO ABIERTO (no piden notas del 1 al 10):\\n{\\n  \"nota_comercial\": null,\\n  \"nota_instalador\": null,\\n  \"nota_rapidez\": null,\\n  \"comentarios\": \"Resumen detallado.\"\\n}\\nTen en cuenta que el tipo de esta evaluación se considera: ${isNumeric ? 'NUMÉRICO' : 'ABIERTO'}.\\nInstrucciones originales del agente:\\n\"\"\"\\n${agent.instructions}\\n\"\"\"`;\n\nreturn [{\n  survey_id: transcriptNode.id,\n  transcription: transcriptNode.transcription,\n  prompt: prompt\n}];"
            },
            "id": "code_prompt",
            "name": "FormatPrompt",
            "position": [
                1104,
                304
            ],
            "type": "n8n-nodes-base.code",
            "typeVersion": 2
        },
        {
            "parameters": {
                "authentication": "predefinedCredentialType",
                "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"{{ $json.prompt }}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.transcription }}\"\n    }\n  ],\n  \"response_format\": { \"type\": \"json_object\" }\n}",
                "method": "POST",
                "nodeCredentialType": "httpHeaderAuth",
                "sendBody": true,
                "sendHeaders": false,
                "specifyBody": "json",
                "url": "https://api.groq.com/openai/v1/chat/completions"
            },
