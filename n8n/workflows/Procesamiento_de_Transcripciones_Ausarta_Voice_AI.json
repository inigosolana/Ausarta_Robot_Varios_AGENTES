            "id": "is_success_llm",
            "name": "IsSuccessLLM",
            "position": [
                1504,
                304
            ],
            "type": "n8n-nodes-base.if",
            "typeVersion": 1
        },
        {
            "parameters": {
                "mode": "runOnceForEachItem",
                "jsCode": "const response = $input.item.json.choices[0].message.content;\nconst promptNode = $('FormatPrompt').first().json;\nconst survey_id = promptNode.survey_id;\nconst transcription = promptNode.transcription;\nlet parsed = {};\nlet isError = false;\nlet errorMsg = null;\ntry {\n  let cleanJson = response.replace(/```json/g, '').replace(/```/g, '').trim();\n  parsed = JSON.parse(cleanJson);\n} catch (e) {\n  isError = true;\n  errorMsg = \"Parse JSON error: \" + response;\n}\nif (isError) {\n  return [{\n    id: survey_id,\n    status: \"failed_parsing\",\n    comentarios: errorMsg\n  }];\n}\nreturn [{\n  id: survey_id,\n  transcription: transcription,\n  nota_comercial: parsed.nota_comercial || null,\n  nota_instalador: parsed.nota_instalador || null,\n  nota_rapidez: parsed.nota_rapidez || null,\n  comentarios: parsed.comentarios || null,\n  llm_model: \"Groq Llama 3.3\",\n  status: \"completed\"\n}];"
            },
            "id": "code_parse",
            "name": "ParseLLMResponse",
            "position": [
                1712,
                208
            ],
            "type": "n8n-nodes-base.code",
            "typeVersion": 2
        },
