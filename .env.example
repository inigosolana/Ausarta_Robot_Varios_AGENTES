# =============================================================================
# Ausarta Voice AI — plantilla de variables (.env.example)
# =============================================================================
#
# ARCHIVOS EN EL REPO:
#   .env.example        → plantilla completa (backend + Docker + build frontend)
#   .env.local.example  → solo variables VITE_* para npm run dev
#
# ARCHIVOS LOCALES (NUNCA commitear):
#   .env                → secretos reales: Docker, backend, agente, worker
#   .env.local          → secretos frontend en desarrollo con Vite
#
# INICIO RÁPIDO:
#   ./scripts/setup-env.sh    # crea .env y .env.local desde plantillas
#   nano .env                 # rellena tus claves
#
# DESPLIEGUE EN SERVIDOR (sin Portainer):
#   ./scripts/deploy-compose.sh
#
# DESARROLLO LOCAL:
#   Frontend:  npm run dev     → lee .env.local (VITE_*)
#   Backend:   usa .env en raíz (setup-env crea backend/.env → ../.env)
#   Docker:    docker compose up  → lee .env en raíz automáticamente
#
# =============================================================================

# --- Entorno general ---
ENVIRONMENT=production
# CORS_ALLOWED_ORIGINS=https://tu-dominio.com,http://localhost:8080

# =============================================================================
# PERFIL A — Desarrollo local (descomenta y ajusta)
# =============================================================================
# ENVIRONMENT=development
# VITE_API_URL=http://localhost:8003
# VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_URL=wss://your-project.livekit.cloud
# FRONTEND_URL=http://localhost:5173
# BRIDGE_SERVER_URL=http://localhost:8001
# AUSARTA_PUBLIC_IP=127.0.0.1

# =============================================================================
# PERFIL B — Servidor self-hosted (ejemplo IP pública)
# =============================================================================
# ENVIRONMENT=production
# VITE_API_URL=http://15.216.15.30:8003
# VITE_LIVEKIT_URL=wss://15.216.15.30:7880
# LIVEKIT_URL=http://15.216.15.30:7880
# FRONTEND_URL=http://15.216.15.30:8080
# AUSARTA_PUBLIC_IP=15.216.15.30
# LIVEKIT_SIP_HOST=15.216.15.30:5070
# VITE_AUSARTA_PUBLIC_IP=15.216.15.30

# =============================================================================
# Supabase (obligatorio)
# =============================================================================
# Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Backend: usa SIEMPRE service role (bypass RLS). No uses anon aquí.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_dashboard
# Anon key (frontend + fallback legacy)
SUPABASE_ANON_KEY=your_supabase_anon_key
# Opcional: solo si algún script antiguo lee SUPABASE_KEY
SUPABASE_KEY=your_supabase_anon_key

# =============================================================================
# Frontend — inyectadas en build Docker (ARG VITE_* en Dockerfile)
# En dev local con Vite, pon las mismas en .env.local
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_URL=http://localhost:8003
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
# VITE_COST_PER_SECOND_EUR=0.002
# VITE_AUSARTA_PUBLIC_IP=203.0.113.10

# =============================================================================
# LiveKit
# =============================================================================
# Backend/agente: wss:// en cloud o http://IP:7880 si LiveKit self-hosted en el mismo servidor
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_ROOM_PREFIX=llamada_ausarta_
LIVEKIT_INBOUND_ROOM_PREFIX=yeastar_
# LIVEKIT_SIP_HOST=your-public-ip:5070

# =============================================================================
# SIP / trunks
# =============================================================================
SIP_OUTBOUND_TRUNK_ID=ST_your_outbound_trunk_id

# Anti toll-fraud — outbound (backend guards)
# SIP_OUTBOUND_GUARDS=true
# SIP_OUTBOUND_MAX_PER_EMPRESA_MINUTE=30
# SIP_OUTBOUND_MAX_PER_DEST_HOUR=3
# SIP_OUTBOUND_ALLOWED_COUNTRY_CODES=34,351
# SIP_OUTBOUND_BLOCK_PREMIUM=true
# SIP_OUTBOUND_BLOCKED_PREFIXES=803,806,807,901,902,905

# =============================================================================
# Bridge API (agente LiveKit → backend FastAPI)
# =============================================================================
# En Docker, BRIDGE_SERVER_URL_INTERNAL lo fija docker-compose (no hace falta cambiarlo)
BRIDGE_SERVER_URL=http://localhost:8001
BRIDGE_SERVER_URL_INTERNAL=http://backend:8001

# =============================================================================
# Redis / ARQ worker
# =============================================================================
# docker-compose construye REDIS_URL con REDIS_PASSWORD automáticamente
REDIS_PASSWORD=generate_a_strong_redis_password
# Solo si corres Redis fuera de Docker:
# REDIS_URL=redis://:password@localhost:6379/0

# =============================================================================
# Proveedores de IA
# =============================================================================
DEEPGRAM_API_KEY=your_deepgram_key
CARTESIA_API_KEY=your_cartesia_key
GROQ_API_KEY=your_groq_key
OPENAI_API_KEY=your_openai_key
GOOGLE_API_KEY=your_google_key_optional

# =============================================================================
# Agente de voz (LiveKit worker)
# =============================================================================
AGENT_NAME_DISPATCH=default_agent
VOICE_ID_AUSARTA=de38f545-c574-44e8-9b54-a7d6fec1c6b1
# VOICE_ID_INES=
# VOICE_ID_ALBA=
# VOICE_ID_ESPANOLA=
# VOICE_ID_JAVIER=
# VOICE_ID_CARLOS=
# VOICE_ID_BUENA=
# AGENT_GREETING_DELAY_SECONDS=0.15
# AGENT_HANGUP_DELAY_SECONDS=0.15

# =============================================================================
# Campañas / goteo
# =============================================================================
MAX_CONCURRENT_CALLS=10
MAX_CALLS_PER_EMPRESA=5
CAMPAIGN_POLL_INTERVAL_SECONDS=30
DRIP_COOLDOWN_MIN_SECONDS=120
DRIP_COOLDOWN_MAX_SECONDS=180
DRIP_AGENT_JOIN_DELAY_SECONDS=3
DRIP_ANSWER_TIMEOUT_SECONDS=30

# =============================================================================
# Telefonía / Yeastar
# =============================================================================
YEASTAR_HUMAN_TRANSFER_EXTENSION=1000
YEASTAR_WEBHOOK_SECRET=generate_a_strong_random_secret
# YEASTAR_IP_WHITELIST=1.2.3.4,5.6.7.8
AUSARTA_PUBLIC_IP=203.0.113.10
FRONTEND_URL=https://app.tudominio.com
# AUSARTA_PUBLIC_WEBHOOK_BASE_URL=https://api.tudominio.com

# =============================================================================
# Auth / multi-tenant
# =============================================================================
IMPERSONATION_SECRET=generate_a_strong_random_secret
IMPERSONATION_TTL_SECONDS=1800
ENCRYPTION_KEY=generate_base64_32_bytes
# AUSARTA_API_KEY=deprecated_legacy_master_key  # Solo para migración — eliminar tras migrar a api_keys en BD
AUSARTA_API_KEY_LEGACY=false  # NUNCA poner true en producción: desactiva aislamiento multi-tenant

# =============================================================================
# N8N webhooks
# =============================================================================
N8N_WEBHOOK_BASE_URL=https://n8n.example.com/webhook
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/transcripciones-voice-ai
N8N_PROXY_SECRET=your_n8n_proxy_secret
# N8N_WEBHOOK_URL_ALERTS=https://n8n.example.com/webhook/alertas-voice-ai

# =============================================================================
# Telegram alertas (opcional)
# =============================================================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# =============================================================================
# SMTP — recuperación de contraseña (opcional)
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=instalaciones@example.com
# SMTP_USE_SSL=false

# =============================================================================
# Grabaciones (opcional)
# =============================================================================
ENABLE_RECORDING=false
# SUPABASE_S3_ACCESS_KEY=
# SUPABASE_S3_SECRET_KEY=
# RECORDING_BUCKET=call-recordings

# =============================================================================
# Integraciones externas (opcional — no usadas por el core del backend)
# =============================================================================
# NOTION_SYNC_N8N_WEBHOOK_URL=
# SUPABASE_WEBHOOK_SECRET=

# =============================================================================
# Dozzle — visor de logs Docker (opcional)
# =============================================================================
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=CAMBIA_ESTO_por_una_contraseña_segura  # OBLIGATORIO — sin esto Dozzle queda sin auth

# =============================================================================
# Avanzado (opcional)
# =============================================================================
# OTEL_ENABLED=false
# LOG_FORMAT=json
# LOG_LEVEL=INFO
# SIP_RETRY_MAX_ATTEMPTS=3
# YEASTAR_HEALTH_CHECK_INTERVAL_SECONDS=120
