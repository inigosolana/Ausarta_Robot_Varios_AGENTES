# ============================================
# Ausarta Robot - Environment Variables
# ============================================
# Copia a .env (backend/Docker) y .env.local (Vite frontend).

# --- Supabase (obligatorio — única persistencia de datos) ---
SUPABASE_URL=https://afrrxeibtrwjaiqmhytu.supabase.co
SUPABASE_KEY=your_service_role_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_dashboard
# SUPABASE_JWT_SECRET_FILE=/run/secrets/supabase_jwt_secret

# --- Frontend (Vite) — mismas credenciales del proyecto ---
VITE_SUPABASE_URL=https://afrrxeibtrwjaiqmhytu.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_URL=http://localhost:8003

# LiveKit Configuration
LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
LIVEKIT_API_KEY=tu_api_key
LIVEKIT_API_SECRET=tu_api_secret
VITE_LIVEKIT_URL=wss://tu-proyecto.livekit.cloud

# SIP Trunk — variable canónica para todas las llamadas salientes
SIP_OUTBOUND_TRUNK_ID=ST_tu_trunk_id
# LIVEKIT_OUTBOUND_TRUNK_ID está DEPRECADO (FIX 6). Usa SIP_OUTBOUND_TRUNK_ID.

# AI Service Providers
DEEPGRAM_API_KEY=tu_deepgram_key
CARTESIA_API_KEY=tu_cartesia_key
GROQ_API_KEY=tu_groq_key
OPENAI_API_KEY=tu_openai_key

# Bridge Server URL (internal — Docker: http://backend:8001)
BRIDGE_SERVER_URL=http://localhost:8001
BRIDGE_SERVER_URL_INTERNAL=http://backend:8001

# Workflow & Drip Control
AGENT_NAME_DISPATCH=default_agent
MAX_CONCURRENT_CALLS=10
CAMPAIGN_POLL_INTERVAL_SECONDS=30
DRIP_COOLDOWN_MIN_SECONDS=120
DRIP_COOLDOWN_MAX_SECONDS=180
DRIP_AGENT_JOIN_DELAY_SECONDS=3
AGENT_CALL_TIMEOUT_SECONDS=600

# Redis (cola ARQ / caché tenant)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# IP pública del servidor (whitelist Yeastar → Integraciones → API). Backend la expone al frontend.
AUSARTA_PUBLIC_IP=203.0.113.10

# Host SIP de LiveKit (servicio livekit-sip) al que Yeastar envía llamadas entrantes.
# Self-hosted: IP:puerto (5070 — el 5060 lo ocupa Asterisk). Cloud: sip.livekit.cloud
# Si no se define, se usa AUSARTA_PUBLIC_IP:5070 automáticamente.
LIVEKIT_SIP_HOST=15.216.15.30:5070

# Optional
GOOGLE_API_KEY=tu_google_key
VITE_COST_PER_SECOND_EUR=0.002

# N8N — webhooks en https://n8n.ausarta.net (proxy exige X-N8N-Secret)
N8N_WEBHOOK_BASE_URL=https://n8n.ausarta.net/webhook
N8N_PROXY_SECRET=ausarta-n8n-secret-2026-XkP9mQ7r

# Recuperación de contraseña (backend)
# Sin SMTP: usa Supabase Auth /recover (misma clave anon que el frontend)
SUPABASE_ANON_KEY=your_supabase_anon_key
# Con SMTP: plantilla Ausarta en español (mismas credenciales que n8n SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=instalaciones@ausarta.es
SMTP_PASSWORD=
SMTP_FROM=instalaciones@ausarta.es
# SMTP_USE_SSL=true  # solo si el servidor usa puerto 465

# ENVIRONMENT=development
# USER_PROFILE_CACHE_TTL_SECONDS=60

# SQLite / DB_PATH — ELIMINADO: no usar bases de datos locales (.db)
