# ============================================
# Ausarta Robot - Environment Variables
# ============================================

# LiveKit Configuration
LIVEKIT_URL=wss://tu-proyecto.livekit.cloud
LIVEKIT_API_KEY=tu_api_key
LIVEKIT_API_SECRET=tu_api_secret

# SIP Trunk
SIP_OUTBOUND_TRUNK_ID=ST_tu_trunk_id

# AI Service Providers
DEEPGRAM_API_KEY=tu_deepgram_key
CARTESIA_API_KEY=tu_cartesia_key
GROQ_API_KEY=tu_groq_key
OPENAI_API_KEY=tu_openai_key

# Database SQLite (local file)
DB_PATH=/app/data/encuestas.db

# Bridge Server URL (internal)
BRIDGE_SERVER_URL=http://localhost:8001

# Workflow & Drip Control
# Nombre del agente LiveKit (debe coincidir con el worker). Si vacío, usa "default_agent"
AGENT_NAME_DISPATCH=default_agent
MAX_CONCURRENT_CALLS=10
CAMPAIGN_POLL_INTERVAL_SECONDS=30
DRIP_COOLDOWN_MIN_SECONDS=120
DRIP_COOLDOWN_MAX_SECONDS=180
# Segundos de espera tras despachar agente antes de iniciar SIP (para que el agente entre en la sala)
DRIP_AGENT_JOIN_DELAY_SECONDS=3
AGENT_CALL_TIMEOUT_SECONDS=600

# Optional: Additional keys
GOOGLE_API_KEY=tu_google_key

# N8N Proxy Security
# Secret compartido con los workflows de n8n para autenticar llamadas server-to-server.
# Debe coincidir con el valor hardcodeado en los nodos ValidateSecret de n8n.
# Valor actual en producción: ausarta-n8n-secret-2026-XkP9mQ7r
N8N_PROXY_SECRET=ausarta-n8n-secret-2026-XkP9mQ7r

# Entorno API: con development puedes omitir AUSARTA_API_KEY solo en local (ver backend/services/auth.py).
# En staging/producción usar production o no definir development.
# ENVIRONMENT=development

# Caché de perfiles en auth (reduce lecturas a user_profiles; TTL en segundos).
# USER_PROFILE_CACHE_TTL_SECONDS=60
