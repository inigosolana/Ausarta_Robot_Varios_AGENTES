# ============================================
# Ausarta Voice AI — Environment Variables
# ============================================
# Copia a `.env` (backend/Docker) y `.env.local` (Vite frontend).
# En producción usa Portainer/stack.env — NUNCA commitees valores reales.

# --- Entorno ---
# ENVIRONMENT=development
# CORS_ALLOWED_ORIGINS=https://app.tudominio.com,http://localhost:8080

# --- Supabase (obligatorio) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_dashboard
# SUPABASE_JWT_SECRET_FILE=/run/secrets/supabase_jwt_secret
SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_PAGE_SIZE=1000
# SUPABASE_MAX_QUERY_PAGES=100

# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_URL=http://localhost:8003
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
# VITE_COST_PER_SECOND_EUR=0.002

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_ROOM_PREFIX=llamada_ausarta_
LIVEKIT_INBOUND_ROOM_PREFIX=yeastar_
# LIVEKIT_SIP_HOST=your-public-ip:5070

# --- SIP / Trunks ---
SIP_OUTBOUND_TRUNK_ID=ST_your_outbound_trunk_id
# LIVEKIT_OUTBOUND_TRUNK_ID=deprecated_use_SIP_OUTBOUND_TRUNK_ID

# --- Bridge API (agente → backend) ---
BRIDGE_SERVER_URL=http://localhost:8001
BRIDGE_SERVER_URL_INTERNAL=http://backend:8001

# --- Redis / ARQ worker ---
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
# ARQ_MAX_JOBS=10
# ARQ_JOB_TIMEOUT=660

# --- AI providers ---
DEEPGRAM_API_KEY=your_deepgram_key
CARTESIA_API_KEY=your_cartesia_key
GROQ_API_KEY=your_groq_key
OPENAI_API_KEY=your_openai_key
GOOGLE_API_KEY=your_google_key_optional
# TRANSCRIPTION_LLM_MODEL=gpt-4o-mini

# --- Agente de voz (LiveKit worker) ---
AGENT_NAME_DISPATCH=default_agent
VOICE_ID_AUSARTA=de38f545-c574-44e8-9b54-a7d6fec1c6b1
# AGENT_GREETING_DELAY_SECONDS=0.15
# AGENT_HANGUP_DELAY_SECONDS=0.15
# AGENT_SILENCE_REPROMPT_SECONDS=7.0
# AGENT_AMD_WINDOW_SECONDS=15.0
# AGENT_CALL_TIMEOUT_SECONDS=600
# AGENT_MIN_SILENCE_SECONDS=0.65
# AGENT_ENDPOINTING_MIN=0.07
# AGENT_ENDPOINTING_MAX=0.5
# AGENT_DEEPGRAM_ENDPOINTING_MS=300
# AGENT_INTERRUPT_MIN_WORDS=3
# AGENT_OFFICE_NOISE=true

# --- Campañas / goteo ---
MAX_CONCURRENT_CALLS=10
MAX_CALLS_PER_EMPRESA=5
CAMPAIGN_POLL_INTERVAL_SECONDS=30
DRIP_COOLDOWN_MIN_SECONDS=120
DRIP_COOLDOWN_MAX_SECONDS=180
DRIP_AGENT_JOIN_DELAY_SECONDS=3
DRIP_ANSWER_TIMEOUT_SECONDS=30
# ORCHESTRATOR_BATCH_SIZE=10
# ORCHESTRATOR_MAX_PARALLEL=5

# --- Telefonía / Yeastar ---
YEASTAR_HUMAN_TRANSFER_EXTENSION=1000
# YEASTAR_IP_WHITELIST=1.2.3.4,5.6.7.8
AUSARTA_PUBLIC_IP=203.0.113.10
# AUSARTA_PUBLIC_WEBHOOK_BASE_URL=https://api.tudominio.com
# FRONTEND_URL=http://localhost:8080
# INVITE_REDIRECT_TO=http://localhost:8080

# --- Auth / multi-tenant ---
# AUSARTA_API_KEY=optional_internal_api_key
# AUSARTA_MASTER_EMPRESA_ID=1
# IMPERSONATION_SECRET=
# IMPERSONATION_TTL_SECONDS=1800
# USER_PROFILE_CACHE_TTL_SECONDS=60

# --- N8N webhooks ---
N8N_WEBHOOK_BASE_URL=https://n8n.example.com/webhook
N8N_PROXY_SECRET=your_n8n_proxy_secret

# --- Telegram alertas ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- SMTP (recuperación contraseña) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=instalaciones@example.com
# SMTP_USE_SSL=false

# --- Grabaciones (opcional) ---
# ENABLE_RECORDING=false
# SUPABASE_S3_ACCESS_KEY=
# SUPABASE_S3_SECRET_KEY=
# RECORDING_BUCKET=call-recordings

# --- Cifrado CRM ---
# ENCRYPTION_KEY=

# --- Logging ---
# LOG_FORMAT=json          # "json" (defecto) o "plain" (legible en desarrollo local)
# LOG_LEVEL=INFO

# --- Rate Limiting por empresa ---
# RATE_LIMIT_DEFAULT_PER_MINUTE=120   # Límite global por defecto (req/min por empresa_id)
# RATE_LIMIT_BURST_MULTIPLIER=2       # Factor burst momentáneo permitido

# --- Health-check Yeastar (cron ARQ worker) ---
# YEASTAR_HEALTH_CHECK_INTERVAL_SECONDS=120   # Intervalo entre comprobaciones (default 120s)
# Telegram opcional para alertas de caída/recuperación (sin vars = health-check sigue activo)
