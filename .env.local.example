# =============================================================================
# Frontend Vite — plantilla (.env.local.example)
# =============================================================================
#
# Uso:
#   cp .env.local.example .env.local
#   nano .env.local
#   npm run dev
#
# Solo variables VITE_* (expuestas al navegador). Nunca pongas service role ni
# secretos de backend aquí.
#
# Backend / Docker / agente → usa .env en la raíz (ver .env.example).
# =============================================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_URL=http://localhost:8003
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_COST_PER_SECOND_EUR=0.002
# IP pública del servidor (whitelist Yeastar P-Series → Integraciones → API)
# VITE_AUSARTA_PUBLIC_IP=203.0.113.10
